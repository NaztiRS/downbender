{
  "manifest_version": 3,
  "name": "Downbender Companion",
  "version": "0.1.4",
  "description": "Send the video that is playing or being previewed to Downbender.",
  "key": "",
  "permissions": [
    "activeTab",
    "contextMenus",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Download with Downbender",
    "default_icon": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "url-utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-128.png"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "incognito": "not_allowed"
}
